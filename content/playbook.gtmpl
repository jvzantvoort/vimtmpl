---
[switches]
header = Add basic header
---
---
{{ if .Enabled "header" }}
#===============================================================================
#
#         FILE:  {{.ScriptName}}
#
#        USAGE:  {{.ScriptName}}
#
#  DESCRIPTION:  {{.Description}}
#
#       AUTHOR:  {{.User}} ({{.UserName}}), {{.MailAddress}}
#
#      CREATED:  {{.Date}}
#
#===============================================================================
{{ end }}
- name: {{.Description}}
  hosts: all



